ENV=dev

# Database
DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
DATABASE_NAME=newlife-core
DATABASE_SCHEMA=public

# Redis (required for auth; optional for rate limiting - when set, limiters use Redis)
REDIS_URL=redis://localhost:6379/0
# Optional: Redis DB number for rate limiter keys (default: 2)
# RATE_LIMITER_REDIS_DB=2

# JWT (required for auth)
JWT_SECRET_KEY=change-me-in-production

# Optional: CORS (default: *)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin Portal URL (CORS / docs)
# ADMIN_PORTAL_URL=http://localhost:5173

# Microsoft Entra ID — Admin Portal SPA (token exchange on POST /admin/api/v1/auth/microsoft)
# Register a Single-page application in Entra; use the same Application (client) ID as VITE_AZURE_CLIENT_ID.
# AZURE_TENANT_ID=your-tenant-id
# AZURE_APP_CLIENT_ID=your-spa-client-id
# AZURE_APP_CLIENT_SECRET=your-app-client-secret
# Required for sync-microsoft-users CLI (Graph client credentials, Application permission User.Read.All + admin consent)
# Optional: override issuer if you use a custom authority (comma-separated for multiple)
# AZURE_ALLOWED_ISSUERS=https://login.microsoftonline.com/your-tenant-id/v2.0

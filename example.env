ENV=dev

# Database
DATABASE_HOST=localhost
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432
DATABASE_NAME=newlife-core
DATABASE_SCHEMA=public

# Redis (required for auth; optional for rate limiting - when set, limiters use Redis)
REDIS_URL=redis://localhost:6379/0
# Optional: Redis DB number for rate limiter keys (default: 2)
# RATE_LIMITER_REDIS_DB=2

# JWT (required for auth)
JWT_SECRET_KEY=change-me-in-production

# Optional: CORS (default: *)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
